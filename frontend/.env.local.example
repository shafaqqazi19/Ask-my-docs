# Backend API base URL used by client-side code (inlined at build time).
# "/api" routes through Next.js API route handlers (recommended for production).
# Set to "http://localhost:8001" for direct local development without the proxy.
NEXT_PUBLIC_API_URL=/api

# Backend URL used by Next.js API route handlers (server-side only, not exposed to browser).
# In Docker Compose, this is the service name: http://ask-my-docs:8001
BACKEND_URL=http://localhost:8001
