# =============================================================================
# Ask My Docs — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Every variable has a safe default for local development.
# For production, set every value explicitly — never commit .env.
#
# Variables marked [compose] are used by docker-compose.yml for service
# configuration. Variables marked [app] are read by the Python/Node code.
# Most are both.
# =============================================================================

# ─── Embedding Model (runs locally via sentence-transformers, no API key) ───
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── Cross-encoder Re-ranker (runs locally via sentence-transformers) ───────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Retrieval Tuning ───────────────────────────────────────────────────────
BM25_TOP_K=25
VECTOR_TOP_K=25
RERANK_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ─── Citation Enforcement ───────────────────────────────────────────────────
# "strip"  — remove unsupported sentences from the answer
# "reject" — refuse the whole answer if any sentence is unsupported
CITATION_POLICY=strip

# ─── Generation ─────────────────────────────────────────────────────────────
# Maximum characters per extracted evidence snippet in the final answer.
GENERATION_MAX_CHARS=500

# ─── Database [compose + app] ──────────────────────────────────────────────
# In Docker Compose, the hostname is the service name: "postgres"
# Outside Docker, use:         postgresql+psycopg://user:pass@localhost:5432/dbname
# For quick local runs:        sqlite:///./local.db
# On HF Spaces: leave empty to disable query logging.
DATABASE_URL=postgresql+psycopg://raguser:ragpass@postgres:5432/askmydocs
LOG_QUERIES=true

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API from a browser.
# Leave empty to allow all origins (safe for local dev, restrict in production).
CORS_ALLOWED_ORIGINS=http://localhost:7860,http://localhost:3000

# ─── Storage Paths ──────────────────────────────────────────────────────────
# Base directory for BM25 and FAISS indexes.
STORAGE_DIR=storage

# ─── Frontend (Next.js) ────────────────────────────────────────────────────
# Client-side API base URL — inlined into the JS bundle at build time.
# "/api" routes through Next.js API route handlers (recommended for production).
NEXT_PUBLIC_API_URL=/api

# Server-side backend URL used by Next.js API route handlers.
# Inside Docker Compose: http://localhost:8001 (same container)
# Outside Docker:        http://localhost:8001
BACKEND_URL=http://localhost:8001

# ─── Postgres [compose only] ───────────────────────────────────────────────
# Used by the postgres service to initialize the database.
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=askmydocs
